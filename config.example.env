# Lanhu MCP Server Configuration (TypeScript)
# Copy this file to .env and fill in your values
# ⚠️ 不要将 .env 文件提交到 git！

# ==============================================
# 必需配置
# ==============================================

# 蓝湖 Cookie（必需）
# 获取方法：登录蓝湖网页版，打开浏览器开发者工具，从请求头中复制 Cookie
LANHU_COOKIE="your_lanhu_cookie_here"

# DDS Cookie（可选，默认同 LANHU_COOKIE）
# DDS_COOKIE=""

# ==============================================
# 服务器配置（可选）
# ==============================================

# 服务器名称
# MCP_SERVER_NAME="lanhu-mcp-ts"

# 蓝湖 API 基础 URL
# LANHU_BASE_URL="https://lanhuapp.com"

# 数据存储目录
# LANHU_DATA_DIR="data/ts"

# HTTP 请求超时（毫秒）
# LANHU_REQUEST_TIMEOUT_MS=20000

# 日志级别 (debug/info/warn/error)
# LOG_LEVEL="info"
